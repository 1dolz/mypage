<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>설정 - 매체 raw 허브</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="top-nav">
    <h1>설정</h1>
    <div>
      <a href="/">Raw 데이터</a>
      <a href="/upload">업로드</a>
      <a href="/settings">설정</a>
      <% if (userEmail) { %><span class="hint" style="margin-left:16px;"><%= userEmail %></span><% } %>
      <a href="/logout">로그아웃</a>
    </div>
  </div>

  <% if (saved) { %><p style="color:#080;">저장되었습니다.</p><% } %>

  <div class="tabs">
    <button type="button" class="tab-btn active" data-tab="general">일반 설정</button>
    <button type="button" class="tab-btn" data-tab="manual">수동 업로드 매체</button>
    <button type="button" class="tab-btn" data-tab="nameindex">이름 매핑</button>
    <% mediaSchema.forEach(m => { %>
      <button type="button" class="tab-btn" data-tab="<%= m.id %>"><%= m.label %></button>
    <% }) %>
  </div>

  <div id="tab-general" class="tab-content active">
    <div class="card">
      <table>
        <tr><th>키</th><th>값</th><th></th></tr>
        <% settings.forEach((s, i) => { %>
          <tr>
            <td style="text-align:left;">
              <input type="text" name="key" value="<%= s.key %>" readonly form="setform-<%= i %>" style="border:none; background:none;">
            </td>
            <td style="text-align:left;">
              <input type="text" name="value" value="<%= s.value %>" form="setform-<%= i %>" style="width:300px;">
            </td>
            <td style="white-space:nowrap;">
              <form id="setform-<%= i %>" method="POST" action="/settings" style="display:inline;">
                <button type="submit" class="secondary">저장</button>
              </form>
              <form method="POST" action="/settings/delete" style="display:inline; margin-left:6px;"
                onsubmit="return confirm('[<%= s.key %>] 설정을 삭제할까요?');">
                <input type="hidden" name="key" value="<%= s.key %>">
                <button type="submit" class="danger">삭제</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </table>
    </div>

    <div class="card">
      <h3 style="margin-top:0;">새 설정 추가</h3>
      <form method="POST" action="/settings">
        <label>키 (예: DELIMITER)</label>
        <input type="text" name="key" style="width:300px;">
        <label>값</label>
        <input type="text" name="value" style="width:300px;">
        <button type="submit">추가</button>
      </form>
    </div>
  </div>

  <%
    const manualFieldDefs = [
      { key: 'date', label: '날짜' },
      { key: 'campaign_name', label: '캠페인' },
      { key: 'adgroup_name', label: '광고그룹' },
      { key: 'ad_name', label: '광고명' },
      { key: 'cost', label: '비용' },
      { key: 'impressions', label: '노출' },
      { key: 'clicks', label: '클릭' },
      { key: 'installs', label: '설치' },
      { key: 'purchases', label: '구매' },
      { key: 'revenue', label: '매출' },
    ];
  %>

  <%
    const isNewManual = !selectedManual;
    const editingManual = selectedManual || { id: '', label: '', field_map: {}, ad_name_prefix: '', cost_multiplier: 1, apply_margin_rate: false };
    const overriddenKeys = new Set(
      manualFieldDefs.filter((f) => editingManual.field_map && editingManual.field_map[f.key]).map((f) => f.key)
    );
  %>

  <div id="tab-manual" class="tab-content">
    <div class="hint" style="margin-bottom:14px;">
      여기서 등록한 매체는 Raw 데이터 화면의 "수동 raw 업로드" 드롭다운에 자동으로 나타납니다.
      아래 "기본값"은 모든 매체에 공통으로 적용되는 컬럼명 후보이고, 특정 매체의 파일만 헤더명이 다르면
      그 매체 설정에서 재정의를 추가하면 됩니다.
    </div>

    <div class="card">
      <h4 style="margin-top:0;">기본값 <span class="hint">(모든 매체에 공통 적용. 실제 파일의 헤더명이 여기 있는 이름과 일치하면 별도 재정의 없이 자동으로 인식됨)</span></h4>
      <form method="POST" action="/settings/manual-defaults">
        <% manualFieldDefs.forEach(f => { %>
          <div class="field-row">
            <label style="width:80px; display:inline-block;"><%= f.label %></label>
            <input type="text" name="default_<%= f.key %>" value="<%= manualDefaults[f.key] || '' %>" style="width:400px;" placeholder="쉼표로 여러 개 가능">
          </div>
        <% }) %>
        <button type="submit">기본값 저장</button>
      </form>
    </div>

    <div class="card">
      <label>매체 선택</label>
      <select id="manual-source-select" style="width:100%; max-width:300px;">
        <% manualSources.forEach(m => { %>
          <option value="<%= m.id %>" <%= selectedManualId === m.id ? 'selected' : '' %>><%= m.label %></option>
        <% }) %>
        <option value="new" <%= isNewManual ? 'selected' : '' %>>+ 새 매체 추가</option>
      </select>
    </div>

    <div class="card">
      <h4 style="margin-top:0;">
        <%= isNewManual ? '새 매체 추가' : (editingManual.label + ' 설정') %>
        <% if (!isNewManual) { %><span class="hint">(id: <%= editingManual.id %>)</span><% } %>
      </h4>
      <form method="POST" action="/settings/manual-sources">
        <% if (isNewManual) { %>
          <div class="field-row">
            <label>매체 ID (영문/숫자/언더스코어, 예: tradingworks)</label>
            <input type="text" name="id" style="width:300px;" required>
          </div>
        <% } else { %>
          <input type="hidden" name="id" value="<%= editingManual.id %>">
        <% } %>
        <div class="field-row">
          <label>표시명</label>
          <input type="text" name="label" value="<%= editingManual.label %>" style="width:300px;">
        </div>

        <div class="field-row">
          <label>컬럼 매핑 재정의 <span class="hint">(실제 파일의 헤더명이 기본값과 다를 때만 지정. 지정한 값이 우선 적용됨)</span></label>
          <div id="override-rows">
            <% manualFieldDefs.forEach(f => { %>
              <% const val = (editingManual.field_map && editingManual.field_map[f.key]) || ''; %>
              <div class="override-row" data-key="<%= f.key %>" style="display:<%= val ? 'flex' : 'none' %>; gap:8px; align-items:center; margin-bottom:6px;">
                <span style="width:80px; font-size:13px; color:#555; flex-shrink:0;"><%= f.label %></span>
                <input type="text" name="field_<%= f.key %>" value="<%= val %>" style="flex:1;" placeholder="쉼표로 여러 개 가능">
                <button type="button" class="secondary remove-override-btn" data-key="<%= f.key %>">제거</button>
              </div>
            <% }) %>
          </div>
          <select id="add-override-select" style="margin-top:6px;">
            <option value="">+ 재정의할 컬럼 선택</option>
            <% manualFieldDefs.filter(f => !overriddenKeys.has(f.key)).forEach(f => { %>
              <option value="<%= f.key %>"><%= f.label %></option>
            <% }) %>
          </select>
        </div>

        <div class="field-row">
          <label>광고명 앞에 붙일 접두어 (선택, 예: keyword_)</label>
          <input type="text" name="ad_name_prefix" value="<%= editingManual.ad_name_prefix || '' %>">
        </div>
        <div class="field-row">
          <label>비용에 곱할 배수 (환율 등, 기본 1)</label>
          <input type="number" step="any" name="cost_multiplier" value="<%= editingManual.cost_multiplier != null ? editingManual.cost_multiplier : 1 %>">
        </div>
        <div class="field-row">
          <label class="checkbox-label">
            <input type="checkbox" name="apply_margin_rate" value="1" <%= editingManual.apply_margin_rate ? 'checked' : '' %>>
            <span>마진율(MARGIN_RATE) 나누기 적용</span>
          </label>
        </div>
        <button type="submit"><%= isNewManual ? '추가' : '저장' %></button>
      </form>

      <% if (!isNewManual) { %>
        <form method="POST" action="/settings/manual-sources/delete" style="display:inline;"
          onsubmit="return confirm('삭제하면 업로드 드롭다운에서 사라집니다. 이미 업로드된 raw 데이터는 남아있습니다. 계속할까요?');">
          <input type="hidden" name="id" value="<%= editingManual.id %>">
          <button type="submit" class="danger">삭제</button>
        </form>
      <% } %>
    </div>
  </div>

  <% mediaSchema.forEach(m => { %>
    <div id="tab-<%= m.id %>" class="tab-content">
      <div class="card">
        <h3 style="margin-top:0;"><%= m.label %> 연동 설정</h3>
        <form method="POST" action="/settings/media">
          <input type="hidden" name="source" value="<%= m.id %>">
          <% m.fields.forEach(f => { %>
            <div class="field-row">
              <label><%= f.label %></label>
              <% if (f.type === 'textarea') { %>
                <textarea name="<%= f.key %>" rows="8" style="width:100%; max-width:480px; box-sizing:border-box; font-family:monospace; font-size:12px;"><%= settingsMap[f.key] || '' %></textarea>
              <% } else { %>
                <input type="<%= f.type || 'text' %>" name="<%= f.key %>" value="<%= settingsMap[f.key] || '' %>">
              <% } %>
            </div>
          <% }) %>
          <button type="submit">저장</button>
        </form>
        <div class="hint">여기 입력한 값은 자동수집(cron) 및 "지금 자동수집 실행"에서 사용됩니다.</div>
      </div>

      <% if (m.id === 'google_ads') { %>
        <div class="card">
          <h3 style="margin-top:0;">Refresh Token 발급 (최초 1회)</h3>
          <div class="hint">
            아직 Refresh Token이 없다면: 먼저 위에서 Client ID / Client Secret을 저장한 뒤,
            아래 링크를 새 탭에서 열어 구글 계정으로 로그인/동의하면 인증 코드가 화면에 표시됩니다.
            그 코드를 복사해서 아래 입력창에 넣고 "발급"을 누르세요.
          </div>
          <p>
            <a
              href="https://accounts.google.com/o/oauth2/auth?client_id=<%= encodeURIComponent(settingsMap.GOOGLE_CLIENT_ID || '') %>&redirect_uri=urn:ietf:wg:oauth:2.0:oob&response_type=code&scope=https://www.googleapis.com/auth/adwords&access_type=offline&prompt=consent"
              target="_blank"
            >인증 URL 열기</a>
          </p>
          <form method="POST" action="/settings/google-ads/exchange-code">
            <label>인증 코드</label>
            <input type="text" name="authCode" style="width:400px;">
            <button type="submit" class="secondary">발급</button>
          </form>
        </div>
      <% } %>

      <% if (m.id === 'tiktok') { %>
        <div class="card">
          <h3 style="margin-top:0;">Access Token 발급 (최초 1회)</h3>
          <div class="hint">
            위에서 App ID / Secret / Auth Code를 먼저 저장한 뒤 아래 버튼을 누르면
            Access Token과 Advertiser ID가 자동으로 발급되어 저장됩니다.
            Auth Code는 1회용이라 실패하면 TikTok에서 새로 발급받아 다시 저장 후 시도하세요.
          </div>
          <form method="POST" action="/settings/tiktok/exchange-code">
            <button type="submit" class="secondary">Access Token 발급</button>
          </form>
        </div>
      <% } %>
    </div>
  <% }) %>

  <div id="tab-nameindex" class="tab-content">
    <div class="card">
      <h3 style="margin-top:0;">이름 매핑 (Index)</h3>
      <p class="hint" style="line-height:1.6;">
        매체가 주는 raw 이름을 표준 이름으로 바꿉니다. 엑셀에서
        <b>매칭값 · 표준 캠페인명 · 표준 광고그룹명 · 표준 광고명</b> 순서(탭 구분)로 복사해 붙여넣으세요.
        뒤쪽 열이나 빈 칸은 원본을 그대로 둡니다. <b>조회·CSV·Excel에 즉시 반영</b>되고 원본 데이터는 바뀌지 않습니다.
      </p>
      <% if (indexSources.length === 0) { %>
        <p class="hint">아직 데이터가 있는 매체가 없습니다. 먼저 수집/업로드하면 매체별로 매핑을 설정할 수 있어요.</p>
      <% } %>
      <% indexSources.forEach(s => { %>
        <form method="POST" action="/settings/name-index" class="field-row"
          style="border-top:1px solid var(--border-color); padding-top:14px; margin-top:14px;">
          <input type="hidden" name="source" value="<%= s %>">
          <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:8px;">
            <strong style="min-width:80px;"><%= s %></strong>
            <label style="margin:0;">매칭 키</label>
            <select name="keyField" style="width:auto;">
              <option value="campaign_name" <%= nameIndexView[s].keyField === 'campaign_name' ? 'selected' : '' %>>캠페인명</option>
              <option value="ad_name" <%= nameIndexView[s].keyField === 'ad_name' ? 'selected' : '' %>>광고명</option>
            </select>
            <button type="submit" class="secondary" style="margin-left:auto;">저장</button>
          </div>
          <textarea name="rows" rows="5" spellcheck="false"
            style="width:100%; box-sizing:border-box; border:1px solid #cbd5e1; border-radius:6px; padding:8px; font-size:12px; white-space:pre; overflow:auto;"
            placeholder="매칭값[탭]표준 캠페인명[탭]표준 광고그룹명[탭]표준 광고명"><%= nameIndexView[s].text %></textarea>
        </form>
      <% }) %>
    </div>
  </div>

  <script>
    document.querySelectorAll('.tab-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach((c) => c.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
      });
    });

    // URL에 #tab-xxx 해시가 있으면 그 탭을 기본으로 활성화 (매체 선택 드롭다운에서 넘어올 때 사용)
    (function () {
      const hashTab = (location.hash || '').replace('#tab-', '');
      if (!hashTab) return;
      const targetBtn = document.querySelector('.tab-btn[data-tab="' + hashTab + '"]');
      if (targetBtn) targetBtn.click();
    })();

    // 수동 업로드 매체 선택 드롭다운: 다른 매체를 고르면 해당 매체 설정으로 다시 로드
    const manualSelect = document.getElementById('manual-source-select');
    if (manualSelect) {
      manualSelect.addEventListener('change', (e) => {
        window.location.href = '/settings?manualId=' + encodeURIComponent(e.target.value) + '#tab-manual';
      });
    }

    // 컬럼 매핑 재정의 행 추가/제거 (선택한 컬럼의 입력창만 보여줌)
    const addOverrideSelect = document.getElementById('add-override-select');
    if (addOverrideSelect) {
      addOverrideSelect.addEventListener('change', (e) => {
        const key = e.target.value;
        if (!key) return;
        const row = document.querySelector('.override-row[data-key="' + key + '"]');
        if (row) {
          row.style.display = 'flex';
          const input = row.querySelector('input[type="text"]');
          if (input) input.focus();
        }
        e.target.value = '';
      });
    }

    document.querySelectorAll('.remove-override-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const row = btn.closest('.override-row');
        const input = row.querySelector('input[type="text"]');
        if (input) input.value = '';
        row.style.display = 'none';
      });
    });
  </script>
</body>
</html>
