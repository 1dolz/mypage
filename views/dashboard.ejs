<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>매체 raw 허브</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="top-nav">
    <h1>매체 raw 허브</h1>
    <div>
      <a href="/">Raw 데이터</a>
      <a href="/upload">업로드</a>
      <a href="/settings">설정</a>
      <% if (userEmail) { %><span class="hint" style="margin-left:16px;"><%= userEmail %></span><% } %>
      <a href="/logout">로그아웃</a>
    </div>
  </div>

  <%
    const columnDefs = [
      { key: 'date', label: '날짜', default: true, group: 'dim' },
      { key: 'source', label: '매체', default: true, group: 'dim' },
      { key: 'campaign_name', label: '캠페인', default: true, group: 'dim' },
      { key: 'adgroup_name', label: '광고그룹', default: true, group: 'dim' },
      { key: 'ad_name', label: '광고명', default: true, group: 'dim' },
      { key: 'cost', label: '비용', default: true, group: 'metric' },
      { key: 'impressions', label: '노출', default: true, group: 'metric' },
      { key: 'clicks', label: '클릭', default: true, group: 'metric' },
      { key: 'installs', label: '설치', default: true, group: 'metric' },
      { key: 'views', label: '조회수', default: false, group: 'metric' },
      { key: 'video_play', label: '6초 재생', default: false, group: 'metric' },
      { key: 'p25', label: '25% 시청', default: false, group: 'metric' },
      { key: 'p50', label: '50% 시청', default: false, group: 'metric' },
      { key: 'p75', label: '75% 시청', default: false, group: 'metric' },
      { key: 'p100', label: '100% 시청', default: false, group: 'metric' },
    ];
    const numericKeys = ['cost','impressions','clicks','views','video_play','p25','p50','p75','p100','installs'];
    const groups = [
      { id: 'dim', title: '차원', items: columnDefs.filter(c => c.group === 'dim') },
      { id: 'metric', title: '지표', items: columnDefs.filter(c => c.group === 'metric') },
    ];
  %>

  <div class="card">
    <div class="ws-layout" id="ws-layout">
      <aside class="column-panel">
        <div class="column-panel-head">
          <span class="column-panel-title">표시 항목</span>
          <button type="button" id="panel-toggle" class="panel-toggle" title="패널 접기" aria-label="패널 접기/펼치기">◀</button>
        </div>
        <div class="column-panel-body">
          <% groups.forEach(g => { %>
            <div class="column-group">
              <div class="column-group-title"><%= g.title %></div>
              <% g.items.forEach(c => { %>
                <label class="col-check"><input type="checkbox" data-col="<%= c.key %>"><span><%= c.label %></span></label>
              <% }) %>
            </div>
          <% }) %>
          <p class="hint" style="margin:8px 0 0;">표의 열 제목을 드래그하면 순서를 바꿀 수 있어요.</p>
        </div>
      </aside>

      <div class="data-panel">
        <div class="toolbar">
          <form id="filter-form" method="GET" action="/" class="filters">
            <div>
              <label>매체</label>
              <select name="source">
                <option value="">전체</option>
                <% sources.forEach(s => { %>
                  <option value="<%= s %>" <%= filters.source === s ? 'selected' : '' %>><%= s %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label>시작일</label>
              <input type="date" name="startDate" value="<%= filters.startDate || '' %>">
            </div>
            <div>
              <label>종료일</label>
              <input type="date" name="endDate" value="<%= filters.endDate || '' %>">
            </div>
            <div style="align-self:end;">
              <button type="submit">조회</button>
            </div>
          </form>
          <div class="toolbar-right">
            <button type="submit" form="filter-form" class="secondary" formaction="/export.csv" formtarget="_blank">CSV로 내보내기</button>
            <button type="submit" form="filter-form" class="secondary" formaction="/export.xlsx" formtarget="_blank">Excel로 내보내기</button>
          </div>
        </div>

        <div class="table-wrap">
          <table id="raw-table">
            <tr>
              <% columnDefs.forEach(c => { %>
                <th data-col="<%= c.key %>"><%= c.label %></th>
              <% }) %>
            </tr>
            <% rows.forEach(r => { %>
              <tr>
                <% columnDefs.forEach(c => { %>
                  <% if (c.key === 'date') { %>
                    <td data-col="date"><%= r.date ? new Date(r.date).toISOString().slice(0,10) : '' %></td>
                  <% } else if (numericKeys.includes(c.key)) { %>
                    <td data-col="<%= c.key %>"><%= Number(r[c.key] || 0).toLocaleString() %></td>
                  <% } else { %>
                    <td data-col="<%= c.key %>" title="<%= r[c.key] %>"><%= r[c.key] %></td>
                  <% } %>
                <% }) %>
              </tr>
            <% }) %>
          </table>
        </div>
        <% if (rows.length === 0) { %><p class="hint">데이터가 없습니다.</p><% } %>

        <div class="system-actions">
          <span class="system-actions-label">관리 작업</span>
          <form method="POST" action="/run-now" class="system-action-form">
            <button type="submit" class="secondary">지금 자동수집 실행</button>
          </form>
          <form method="POST" action="/delete-source" class="system-action-form"
            onsubmit="return confirm('선택한 매체의 raw 데이터를 전부 삭제합니다. 계속할까요?');">
            <select name="source">
              <% sources.forEach(s => { %>
                <option value="<%= s %>"><%= s %></option>
              <% }) %>
            </select>
            <button type="submit" class="danger">선택 매체 데이터 삭제</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      const COLUMN_DEFS = <%- JSON.stringify(columnDefs.map(c => ({ key: c.key, label: c.label }))) %>;
      const DEFAULT_VISIBLE = <%- JSON.stringify(columnDefs.filter(c => c.default).map(c => c.key)) %>;
      const STORAGE_KEY = 'dashboardVisibleColumns'; // 표시 컬럼 key 배열 (표시 순서 그대로)
      const COLLAPSE_KEY = 'dashboardPanelCollapsed';

      const labelByKey = {};
      COLUMN_DEFS.forEach((c) => { labelByKey[c.key] = c.label; });

      const layout = document.getElementById('ws-layout');
      const table = document.getElementById('raw-table');
      const checks = Array.from(document.querySelectorAll('.col-check input[type="checkbox"]'));
      const ths = Array.from(table.querySelectorAll('th'));

      function loadOrder() {
        try {
          const saved = JSON.parse(localStorage.getItem(STORAGE_KEY));
          if (Array.isArray(saved)) {
            const valid = saved.filter((k) => labelByKey[k]);
            if (valid.length) return valid;
          }
        } catch (e) {}
        return DEFAULT_VISIBLE.slice();
      }

      function saveOrder(order) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(order));
      }

      // th/td를 order 순서대로 재배치하고, 미선택 컬럼은 숨김
      function applyColumnLayout(order) {
        const selectedSet = new Set(order);
        document.querySelectorAll('#raw-table tr').forEach((tr) => {
          const cells = Array.from(tr.children);
          const cellMap = {};
          cells.forEach((c) => { cellMap[c.dataset.col] = c; });
          order.forEach((key) => {
            const cell = cellMap[key];
            if (cell) tr.appendChild(cell);
          });
          cells.forEach((c) => {
            c.style.display = selectedSet.has(c.dataset.col) ? '' : 'none';
          });
        });
      }

      // 좌측 체크박스 상태를 현재 표시 컬럼과 동기화
      function syncChecks(order) {
        const selectedSet = new Set(order);
        checks.forEach((cb) => { cb.checked = selectedSet.has(cb.dataset.col); });
      }

      // 현재 표에 실제로 보이는 th 순서 = 현재 order
      function orderFromTable() {
        return ths.filter((th) => th.style.display !== 'none').map((th) => th.dataset.col);
      }

      function update(order) {
        saveOrder(order);
        applyColumnLayout(order);
        syncChecks(order);
      }

      // 체크박스: 컬럼 표시/숨김 토글 (숨겼다 다시 켜면 맨 뒤에 추가)
      checks.forEach((cb) => {
        cb.addEventListener('change', () => {
          let order = orderFromTable();
          if (cb.checked) {
            if (!order.includes(cb.dataset.col)) order.push(cb.dataset.col);
          } else {
            order = order.filter((k) => k !== cb.dataset.col);
          }
          update(order);
        });
      });

      // 표 헤더(th) 드래그로 컬럼 순서 변경
      let draggingCol = null;
      ths.forEach((th) => {
        th.setAttribute('draggable', 'true');
        th.addEventListener('dragstart', (e) => {
          draggingCol = th.dataset.col;
          th.classList.add('col-dragging');
          e.dataTransfer.effectAllowed = 'move';
        });
        th.addEventListener('dragend', () => {
          th.classList.remove('col-dragging');
          ths.forEach((h) => h.classList.remove('col-drag-over'));
          draggingCol = null;
        });
        th.addEventListener('dragover', (e) => {
          if (!draggingCol || th.dataset.col === draggingCol || th.style.display === 'none') return;
          e.preventDefault();
          ths.forEach((h) => h.classList.remove('col-drag-over'));
          th.classList.add('col-drag-over');
        });
        th.addEventListener('drop', (e) => {
          e.preventDefault();
          if (!draggingCol || th.dataset.col === draggingCol) return;
          const order = orderFromTable();
          const from = order.indexOf(draggingCol);
          if (from === -1) return;
          order.splice(from, 1);
          const to = order.indexOf(th.dataset.col);
          if (to === -1) return;
          const rect = th.getBoundingClientRect();
          const after = e.clientX > rect.left + rect.width / 2;
          order.splice(after ? to + 1 : to, 0, draggingCol);
          update(order);
        });
      });

      // 좌측 패널 접기/펼치기
      const toggle = document.getElementById('panel-toggle');
      function applyCollapse(collapsed) {
        layout.classList.toggle('is-collapsed', collapsed);
        toggle.textContent = collapsed ? '▶' : '◀';
        toggle.title = collapsed ? '패널 펼치기' : '패널 접기';
      }
      toggle.addEventListener('click', () => {
        const collapsed = !layout.classList.contains('is-collapsed');
        localStorage.setItem(COLLAPSE_KEY, collapsed ? '1' : '0');
        applyCollapse(collapsed);
      });
      applyCollapse(localStorage.getItem(COLLAPSE_KEY) === '1');

      update(loadOrder());
    })();
  </script>
</body>
</html>
