<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>매체 raw 허브</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="top-nav">
    <h1>매체 raw 허브</h1>
    <div>
      <a href="/">Raw 데이터</a>
      <a href="/upload">업로드</a>
      <a href="/settings">설정</a>
      <% if (userEmail) { %><span class="hint" style="margin-left:16px;"><%= userEmail %></span><% } %>
      <a href="/logout">로그아웃</a>
    </div>
  </div>

  <div class="card">
    <form method="GET" action="/" class="filters">
      <div>
        <label>매체</label>
        <select name="source">
          <option value="">전체</option>
          <% sources.forEach(s => { %>
            <option value="<%= s %>" <%= filters.source === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label>시작일</label>
        <input type="date" name="startDate" value="<%= filters.startDate || '' %>">
      </div>
      <div>
        <label>종료일</label>
        <input type="date" name="endDate" value="<%= filters.endDate || '' %>">
      </div>
      <div style="align-self:end;">
        <button type="submit">조회</button>
      </div>
      <div style="align-self:end;">
        <button type="submit" class="secondary" formaction="/export.csv" formtarget="_blank">CSV로 내보내기</button>
      </div>
      <div style="align-self:end;">
        <button type="submit" class="secondary" formaction="/export.xlsx" formtarget="_blank">Excel로 내보내기</button>
      </div>
    </form>
    <form method="POST" action="/run-now" style="display:inline;">
      <button type="submit" class="secondary">지금 자동수집 실행</button>
    </form>

    <form method="POST" action="/delete-source" style="display:inline; margin-left:8px;"
      onsubmit="return confirm('선택한 매체의 raw 데이터를 전부 삭제합니다. 계속할까요?');">
      <select name="source">
        <% sources.forEach(s => { %>
          <option value="<%= s %>"><%= s %></option>
        <% }) %>
      </select>
      <button type="submit" class="danger">선택 매체 데이터 삭제</button>
    </form>

    <%
      const columnDefs = [
        { key: 'date', label: '날짜', default: true },
        { key: 'source', label: '매체', default: true },
        { key: 'campaign_name', label: '캠페인', default: true },
        { key: 'adgroup_name', label: '광고그룹', default: true },
        { key: 'ad_name', label: '광고명', default: true },
        { key: 'cost', label: '비용', default: true },
        { key: 'impressions', label: '노출', default: true },
        { key: 'clicks', label: '클릭', default: true },
        { key: 'views', label: '조회수', default: false },
        { key: 'video_play', label: '6초 재생', default: false },
        { key: 'p25', label: '25% 시청', default: false },
        { key: 'p50', label: '50% 시청', default: false },
        { key: 'p75', label: '75% 시청', default: false },
        { key: 'p100', label: '100% 시청', default: false },
        { key: 'installs', label: '설치', default: true },
      ];
    %>

    <div class="col-picker">
      <div class="col-picker-header">
        <span class="hint" style="margin:0;">표시할 항목 (드래그해서 순서 변경 가능):</span>
        <select id="add-column-select">
          <option value="">+ 항목 추가</option>
          <% columnDefs.forEach(c => { %>
            <option value="<%= c.key %>" data-label="<%= c.label %>"><%= c.label %></option>
          <% }) %>
        </select>
      </div>
      <div id="selected-columns-chips" class="col-chip-list"></div>
    </div>

    <div class="table-wrap">
      <table id="raw-table">
        <tr>
          <% columnDefs.forEach(c => { %>
            <th data-col="<%= c.key %>"><%= c.label %></th>
          <% }) %>
        </tr>
        <% rows.forEach(r => { %>
          <tr>
            <% columnDefs.forEach(c => { %>
              <% if (c.key === 'date') { %>
                <td data-col="date"><%= r.date ? new Date(r.date).toISOString().slice(0,10) : '' %></td>
              <% } else if (['cost','impressions','clicks','views','video_play','p25','p50','p75','p100','installs'].includes(c.key)) { %>
                <td data-col="<%= c.key %>"><%= Number(r[c.key] || 0).toLocaleString() %></td>
              <% } else { %>
                <td data-col="<%= c.key %>"><%= r[c.key] %></td>
              <% } %>
            <% }) %>
          </tr>
        <% }) %>
      </table>
    </div>
    <% if (rows.length === 0) { %><p class="hint">데이터가 없습니다.</p><% } %>
  </div>

  <script>
    (function () {
      const COLUMN_DEFS = <%- JSON.stringify(columnDefs.map(c => ({ key: c.key, label: c.label }))) %>;
      const DEFAULT_VISIBLE = <%- JSON.stringify(columnDefs.filter(c => c.default).map(c => c.key)) %>;
      const STORAGE_KEY = 'dashboardVisibleColumns'; // 값: 선택된 컬럼 key 배열 (표시 순서 그대로)

      const labelByKey = {};
      COLUMN_DEFS.forEach((c) => { labelByKey[c.key] = c.label; });

      const chipList = document.getElementById('selected-columns-chips');
      const addSelect = document.getElementById('add-column-select');

      function loadOrder() {
        try {
          const saved = JSON.parse(localStorage.getItem(STORAGE_KEY));
          if (Array.isArray(saved)) return saved.filter((k) => labelByKey[k]);
        } catch (e) {}
        return DEFAULT_VISIBLE.slice();
      }

      function saveOrder(order) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(order));
      }

      // 실제 테이블의 th/td를 선택된 순서대로 재배치하고, 선택 안 된 항목은 숨김
      function applyColumnLayout(order) {
        const selectedSet = new Set(order);
        document.querySelectorAll('#raw-table tr').forEach((tr) => {
          const cells = Array.from(tr.children);
          const cellMap = {};
          cells.forEach((c) => { cellMap[c.dataset.col] = c; });
          order.forEach((key) => {
            const cell = cellMap[key];
            if (cell) tr.appendChild(cell);
          });
          cells.forEach((c) => {
            c.style.display = selectedSet.has(c.dataset.col) ? '' : 'none';
          });
        });
      }

      function renderAddSelect(order) {
        const selectedSet = new Set(order);
        addSelect.innerHTML = '<option value="">+ 항목 추가</option>';
        COLUMN_DEFS.forEach((c) => {
          if (selectedSet.has(c.key)) return;
          const opt = document.createElement('option');
          opt.value = c.key;
          opt.textContent = c.label;
          addSelect.appendChild(opt);
        });
      }

      function renderChips(order) {
        chipList.innerHTML = '';
        order.forEach((key) => {
          const label = labelByKey[key];
          if (!label) return;
          const chip = document.createElement('div');
          chip.className = 'col-chip';
          chip.draggable = true;
          chip.dataset.col = key;
          chip.innerHTML =
            '<span class="col-chip-handle">⠿</span><span class="col-chip-text"></span>' +
            '<button type="button" class="col-chip-remove" title="제거">×</button>';
          chip.querySelector('.col-chip-text').textContent = label;
          chipList.appendChild(chip);
        });
      }

      function update(order) {
        saveOrder(order);
        renderChips(order);
        renderAddSelect(order);
        applyColumnLayout(order);
        attachChipEvents();
      }

      function attachChipEvents() {
        const chips = Array.from(chipList.querySelectorAll('.col-chip'));

        chips.forEach((chip) => {
          chip.querySelector('.col-chip-remove').addEventListener('click', () => {
            const order = getCurrentOrder().filter((k) => k !== chip.dataset.col);
            update(order);
          });

          chip.addEventListener('dragstart', () => {
            chip.classList.add('dragging');
          });
          chip.addEventListener('dragend', () => {
            chip.classList.remove('dragging');
            chips.forEach((c) => c.classList.remove('drag-over'));
            const order = Array.from(chipList.querySelectorAll('.col-chip')).map((c) => c.dataset.col);
            update(order);
          });
          chip.addEventListener('dragover', (e) => {
            e.preventDefault();
            const dragging = chipList.querySelector('.col-chip.dragging');
            if (!dragging || dragging === chip) return;
            chips.forEach((c) => c.classList.remove('drag-over'));
            chip.classList.add('drag-over');
            const rect = chip.getBoundingClientRect();
            const before = e.clientX < rect.left + rect.width / 2;
            chipList.insertBefore(dragging, before ? chip : chip.nextSibling);
          });
        });
      }

      function getCurrentOrder() {
        return Array.from(chipList.querySelectorAll('.col-chip')).map((c) => c.dataset.col);
      }

      addSelect.addEventListener('change', (e) => {
        const key = e.target.value;
        if (!key) return;
        const order = getCurrentOrder();
        order.push(key);
        update(order);
        addSelect.value = '';
      });

      update(loadOrder());
    })();
  </script>
</body>
</html>
