<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>매체 raw 허브</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="top-nav">
    <h1>매체 raw 허브</h1>
    <div>
      <a href="/">Raw 데이터</a>
      <a href="/settings">설정</a>
      <a href="/logout">로그아웃</a>
    </div>
  </div>

  <div class="card">
    <h3 style="margin-top:0;">수동 raw 업로드</h3>
    <form method="POST" action="/upload" enctype="multipart/form-data">
      <div style="display:flex; gap:12px; align-items:end; flex-wrap:wrap;">
        <div>
          <label>매체</label>
          <select name="source">
            <option value="tenping">텐핑</option>
            <option value="valista">바리스타</option>
            <option value="appier">Appier</option>
            <option value="asa_raw">ASA raw</option>
            <option value="x_raw">X raw</option>
          </select>
        </div>
        <div>
          <label>CSV/Excel 파일</label>
          <input type="file" name="file" accept=".csv,.xlsx,.xls" required>
        </div>
        <button type="submit">업로드</button>
      </div>
      <div class="hint">업로드하면 해당 매체의 기존 데이터를 새 파일 내용으로 교체합니다.</div>
    </form>
  </div>

  <div class="card">
    <form method="GET" action="/" class="filters">
      <div>
        <label>매체</label>
        <select name="source">
          <option value="">전체</option>
          <% sources.forEach(s => { %>
            <option value="<%= s %>" <%= filters.source === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label>시작일</label>
        <input type="date" name="startDate" value="<%= filters.startDate || '' %>">
      </div>
      <div>
        <label>종료일</label>
        <input type="date" name="endDate" value="<%= filters.endDate || '' %>">
      </div>
      <div style="align-self:end;">
        <button type="submit">조회</button>
      </div>
      <div style="align-self:end;">
        <button type="submit" class="secondary" formaction="/export.csv" formtarget="_blank">CSV로 내보내기</button>
      </div>
      <div style="align-self:end;">
        <button type="submit" class="secondary" formaction="/export.xlsx" formtarget="_blank">Excel로 내보내기</button>
      </div>
    </form>
    <form method="POST" action="/run-now" style="display:inline;">
      <button type="submit" class="secondary">지금 자동수집 실행</button>
    </form>

    <form method="POST" action="/delete-source" style="display:inline; margin-left:8px;"
      onsubmit="return confirm('선택한 매체의 raw 데이터를 전부 삭제합니다. 계속할까요?');">
      <select name="source">
        <% sources.forEach(s => { %>
          <option value="<%= s %>"><%= s %></option>
        <% }) %>
      </select>
      <button type="submit" class="secondary">선택 매체 데이터 삭제</button>
    </form>

    <%
      const columnDefs = [
        { key: 'date', label: '날짜', default: true },
        { key: 'source', label: '매체', default: true },
        { key: 'campaign_name', label: '캠페인', default: true },
        { key: 'adgroup_name', label: '광고그룹', default: true },
        { key: 'ad_name', label: '광고명', default: true },
        { key: 'cost', label: '비용', default: true },
        { key: 'impressions', label: '노출', default: true },
        { key: 'clicks', label: '클릭', default: true },
        { key: 'views', label: '조회수', default: false },
        { key: 'video_play', label: '6초 재생', default: false },
        { key: 'p25', label: '25% 시청', default: false },
        { key: 'p50', label: '50% 시청', default: false },
        { key: 'p75', label: '75% 시청', default: false },
        { key: 'p100', label: '100% 시청', default: false },
        { key: 'installs', label: '설치', default: true },
      ];
    %>

    <div class="col-toggles">
      <span class="hint" style="margin:0;">표시할 항목:</span>
      <% columnDefs.forEach(c => { %>
        <label class="col-toggle-label">
          <input type="checkbox" class="col-toggle" data-col="<%= c.key %>" checked>
          <%= c.label %>
        </label>
      <% }) %>
    </div>

    <div class="table-wrap">
      <table id="raw-table">
        <tr>
          <% columnDefs.forEach(c => { %>
            <th data-col="<%= c.key %>"><%= c.label %></th>
          <% }) %>
        </tr>
        <% rows.forEach(r => { %>
          <tr>
            <% columnDefs.forEach(c => { %>
              <% if (c.key === 'date') { %>
                <td data-col="date"><%= r.date ? new Date(r.date).toISOString().slice(0,10) : '' %></td>
              <% } else if (['cost','impressions','clicks','views','video_play','p25','p50','p75','p100','installs'].includes(c.key)) { %>
                <td data-col="<%= c.key %>"><%= Number(r[c.key] || 0).toLocaleString() %></td>
              <% } else { %>
                <td data-col="<%= c.key %>"><%= r[c.key] %></td>
              <% } %>
            <% }) %>
          </tr>
        <% }) %>
      </table>
    </div>
    <% if (rows.length === 0) { %><p class="hint">데이터가 없습니다.</p><% } %>
  </div>

  <script>
    (function () {
      const DEFAULT_VISIBLE = <%- JSON.stringify(columnDefs.filter(c => c.default).map(c => c.key)) %>;
      const STORAGE_KEY = 'dashboardVisibleColumns';

      function getVisible() {
        try {
          const saved = JSON.parse(localStorage.getItem(STORAGE_KEY));
          if (Array.isArray(saved)) return saved;
        } catch (e) {}
        return DEFAULT_VISIBLE;
      }

      function applyVisibility(visible) {
        document.querySelectorAll('#raw-table [data-col]').forEach((el) => {
          el.style.display = visible.includes(el.dataset.col) ? '' : 'none';
        });
        document.querySelectorAll('.col-toggle').forEach((cb) => {
          cb.checked = visible.includes(cb.dataset.col);
        });
      }

      document.querySelectorAll('.col-toggle').forEach((cb) => {
        cb.addEventListener('change', () => {
          const visible = Array.from(document.querySelectorAll('.col-toggle:checked')).map((c) => c.dataset.col);
          localStorage.setItem(STORAGE_KEY, JSON.stringify(visible));
          applyVisibility(visible);
        });
      });

      applyVisibility(getVisible());
    })();
  </script>
</body>
</html>
