<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>회원가입 - 매체 raw 허브</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="login-box card">
    <h1>매체 raw 허브</h1>
    <div class="hint" style="margin-bottom:10px;">
      <% if (allowedDomain === '*') { %>이메일과 비밀번호로 가입할 수 있습니다.<% } else { %>@<%= allowedDomain %> 이메일로만 가입할 수 있습니다.<% } %>
    </div>
    <form method="POST" action="/signup">
      <label>이메일</label>
      <input type="email" name="email" placeholder="<%= allowedDomain === '*' ? 'you@example.com' : ('you@' + allowedDomain) %>" autofocus style="width:100%; box-sizing:border-box;">
      <label>비밀번호 (8자 이상)</label>
      <input type="password" name="password" style="width:100%; box-sizing:border-box;">
      <label>비밀번호 확인</label>
      <input type="password" name="passwordConfirm" style="width:100%; box-sizing:border-box;">
      <button type="submit" style="width:100%;">회원가입</button>
    </form>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <div class="hint" style="margin-top:14px;">
      이미 계정이 있으신가요? <a href="/login">로그인</a>
    </div>
  </div>
</body>
</html>
